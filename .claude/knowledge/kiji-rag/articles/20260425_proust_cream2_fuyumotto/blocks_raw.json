      "block_type": "text",
      "content": "だから、冬の方がクサくなる。",
      "heading_level": "body",
      "tag_hint": "p",
      "is_cta_block": false
    },
    {
      "order": 73,
      "block_type": "text",
      "content": "まさに冬は「ワキガ菌の繁忙期」",
      "heading_level": "body",
      "tag_hint": "p",
      "is_cta_block": false
    },
    {
      "order": 74,
      "block_type": "video",
      "media_url": "https://file.mysquadbeyond.com/uploads/article_photo/photo/6023424/4dfbc5c4-4d34-40ea-88e8-20aaa7a4dcb1.mp4",
      "caption": "※画像はイメージです",
      "is_cta_block": false
    },
