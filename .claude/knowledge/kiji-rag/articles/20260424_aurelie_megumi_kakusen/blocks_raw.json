    {"order": 138, "block_type": "image", "media_url": "https://file.mysquadbeyond.com/lazy.png", "alt_text": "", "caption": ""},
    {"order": 139, "block_type": "text", "content": "高級毛穴ケアセットが 1本あたり1,980円(税込)＋無料🎁 ドラコス価格で手に入る!", "tag_hint": "p", "is_cta_block": true},
    {"order": 140, "block_type": "image", "media_url": "https://file.mysquadbeyond.com/lazy.png", "alt_text": "", "caption": ""},
    {"order": 141, "block_type": "text", "content": "みなさんが羨ましい😭 私は楽天で約12,000円で買ったのに… 9,000円くらい損しちゃいました…", "tag_hint": "p"},
    {"order": 142, "block_type": "image", "media_url": "https://file.mysquadbeyond.com/lazy.png", "alt_text": "", "caption": ""},
    {"order": 143, "block_type": "text", "content": "これ、調べ尽くしましたが どこよりもお得です！", "tag_hint": "p"},
    {"order": 144, "block_type": "image", "media_url": "https://file.mysquadbeyond.com/lazy.png", "alt_text": "", "caption": ""},
    {"order": 145, "block_type": "text", "content": "今スルーすると損！と心から言えます🫣", "tag_hint": "p"},
