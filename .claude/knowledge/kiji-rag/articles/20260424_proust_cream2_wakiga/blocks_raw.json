    {"order": 64, "block_type": "text", "content": "POINT さらにワキガに効く※ 薬用ワキガ外用剤とは？", "heading_level": "h2", "tag_hint": "h2", "is_cta_block": false},
    {"order": 65, "block_type": "text", "content": "\\34万人に使われた/ ワキガ対策の待望の最新作！！", "heading_level": "h3", "tag_hint": "h3", "is_cta_block": false},
    {"order": 66, "block_type": "image", "media_url": "https://file.mysquadbeyond.com/lazy.png", "alt_text": "lazy placeholder", "is_cta_block": false},
